generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum UserRole {
  ADMIN
  CLIENT
  VA
}

enum CourseLevel {
  BASIC
  INTERMEDIATE
  ADVANCED
}

enum JobType {
  HOURLY
  FIXED
}

// Core User Models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(VA)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile       Profile?
  enrollments   Enrollment[]
  clientJobs    Job[]        @relation("ClientJobs")
  proposals     Proposal[]
  certifications Certification[]
  
  accounts      Account[]
  sessions      Session[]
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio         String?
  title       String?
  hourlyRate  Decimal?
  skills      String[]
  englishLevel String? // e.g., B2, C1
  videoUrl    String?
  resumeUrl   String?
  
  updatedAt   DateTime @updatedAt
}

// NextAuth Models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// LMS Models
model Course {
  id          String      @id @default(cuid())
  title       String
  description String
  thumbnail   String?
  level       CourseLevel
  published   Boolean     @default(false)
  price       Decimal     @default(0) // 0 for free
  
  modules     Module[]
  enrollments Enrollment[]
  certifications Certification[]
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Module {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title     String
  order     Int      @default(0)
  
  lessons   Lesson[]
}

model Lesson {
  id        String   @id @default(cuid())
  moduleId  String
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title     String
  content   String?  // Markdown or HTML
  videoUrl  String?
  order     Int      @default(0)
  
  quiz      Quiz?
  progress  LessonProgress[]
}

model Quiz {
  id        String     @id @default(cuid())
  lessonId  String     @unique
  lesson    Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  questions Question[]
}

model Question {
  id            String   @id @default(cuid())
  quizId        String
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  text          String
  options       String[] // ["A", "B", "C", "D"]
  correctOption Int      // Index of correct option
}

// Tracking & Certs
model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  completedAt DateTime?
  progress    LessonProgress[]
  
  createdAt DateTime @default(now())
  @@unique([userId, courseId])
}

model LessonProgress {
  id           String     @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lessonId     String
  lesson       Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  completed    Boolean    @default(false)
  
  @@unique([enrollmentId, lessonId])
}

model Certification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  issuedAt  DateTime @default(now())
  badgeUrl  String?
  
  @@unique([userId, courseId])
}

// Marketplace Models
model Job {
  id          String   @id @default(cuid())
  clientId    String
  client      User     @relation("ClientJobs", fields: [clientId], references: [id])
  title       String
  description String
  budget      Decimal?
  type        JobType
  status      String   @default("OPEN") // OPEN, CLOSED, IN_PROGRESS
  
  proposals   Proposal[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Proposal {
  id          String   @id @default(cuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  vaId        String
  va          User     @relation(fields: [vaId], references: [id])
  
  coverLetter String
  bidAmount   Decimal
  status      String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  
  createdAt   DateTime @default(now())
}
